# Normalize line endings to LF for all text files
* text=auto eol=lf

# Scala source files
*.scala text eol=lf
*.sbt   text eol=lf
*.sc    text eol=lf

# Config and build files
*.conf  text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.json  text eol=lf
*.xml   text eol=lf
*.toml  text eol=lf
*.properties text eol=lf

# Documentation
*.md    text eol=lf
*.txt   text eol=lf

# Shell scripts always LF
*.sh    text eol=lf

# Windows scripts keep CRLF
*.bat   text eol=crlf
*.cmd   text eol=crlf

# Binary files - no EOL conversion
*.jar   binary
*.class binary
*.png   binary
*.jpg   binary
*.gif   binary
*.zip   binary

